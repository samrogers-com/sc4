{
    "family": "sams-collectibles-task",
    "taskRoleArn": "arn:aws:iam::REDACTED-AWS-ACCOUNT-ID:role/sams-collectibles-task-role",
    "executionRoleArn": "arn:aws:iam::REDACTED-AWS-ACCOUNT-ID:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "containerDefinitions": [
      {
        "name": "sams-collectibles-web",
        "image": "REDACTED-AWS-ACCOUNT-ID.dkr.ecr.us-west-2.amazonaws.com/sams-collectibles:latest",
        "cpu": 256,
        "memory": 512,
        "essential": true,
        "secrets": [
          {
            "name": "DB_USER",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_USER"
          },
          {
            "name": "DB_PASSWORD",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_PASSWORD"
          },
          {
            "name": "DB_NAME",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_NAME"
          },
          {
            "name": "DB_HOST",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_HOST"
          },
          {
            "name": "DB_PORT",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_PORT"
          },
          {
            "name": "DJANGO_SECRET_KEY",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-django-secret-97Attw#DJANGO_SECRET_KEY"
          },
          {
            "name": "POSTGRES_URL",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#database_url"
          }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/sams-collectibles",
            "awslogs-region": "us-west-2",
            "awslogs-stream-prefix": "ecs"
          }
        }
      },
      {
        "name": "sams-collectibles-db",
        "image": "postgres:13",
        "cpu": 256,
        "memory": 512,
        "essential": true,
        "secrets": [
          {
            "name": "DB_USER",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_USER"
          },
          {
            "name": "DB_PASSWORD",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_PASSWORD"
          },
          {
            "name": "DB_NAME",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_NAME"
          },
          {
            "name": "DB_HOST",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_HOST"
          },
          {
            "name": "DB_PORT",
            "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj#DB_PORT"
          }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/sams-collectibles",
            "awslogs-region": "us-west-2",
            "awslogs-stream-prefix": "ecs"
          }
        }
      }
    ],
    "requiresCompatibilities": [
      "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024"
  }