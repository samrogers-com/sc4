{
  "family": "sams-collectibles-task",
  "containerDefinitions": [
    {
      "name": "sams-collectibles-web",
      "image": "REDACTED-AWS-ACCOUNT-ID.dkr.ecr.us-west-2.amazonaws.com/sams-collectibles:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        },
        {
          "containerPort": 8001,
          "hostPort": 8001,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "secrets": [
        {
          "name": "DJANGO_ENV",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-django-secret-97Attw:DJANGO_ENV"
        },
        {
          "name": "DEBUG",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-django-secret-97Attw:DEBUG"
        },
        {
          "name": "USE_POSTGRES",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-django-secret-97Attw:USE_POSTGRES"
        },
        {
          "name": "DJANGO_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-django-secret-97Attw:DJANGO_SECRET_KEY"
        },
        {
          "name": "ALLOWED_HOSTS",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-django-secret-97Attw:ALLOWED_HOSTS"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sams-collectibles",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    },
    {
      "name": "sams-collectibles-db",
      "image": "postgres:13",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 5432,
          "hostPort": 5432,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "secrets": [
        {
          "name": "username",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj:username"
        },
        {
          "name": "password",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj:password"
        },
        {
          "name": "dbname",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj:dbname"
        },
        {
          "name": "host",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj:host"
        },
        {
          "name": "port",
          "valueFrom": "arn:aws:secretsmanager:us-west-2:REDACTED-AWS-ACCOUNT-ID:secret:sams-collectibles-db-secret-m7JTbj:port"
        }
      ],
      "systemControls": []
    }
  ],
  "taskRoleArn": "arn:aws:iam::REDACTED-AWS-ACCOUNT-ID:role/sams-collectibles-task-role",
  "executionRoleArn": "arn:aws:iam::REDACTED-AWS-ACCOUNT-ID:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "requiresCompatibilities": [
    "FARGATE"
  ]
}