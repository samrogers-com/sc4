DJANGO_SETTINGS_MODULE=samscollectibles.settings.production
ENV_PATH=/usr/src/app/samscollectibles/.env.production

SECRET_KEY={{ vault_secret_key }}
DEBUG=False
ALLOWED_HOSTS={{ domain }},{{ domain_www }}

# PostgreSQL
USE_POSTGRES=True
DB_ENGINE=django.db.backends.postgresql
DB_NAME=samscollectibles
DB_USER=samscollectibles_user
DB_PASSWORD={{ vault_db_password }}
DB_HOST=db
DB_PORT=5432

# Cloudflare R2
USE_REMOTE_STORAGE=True
R2_ACCESS_KEY_ID={{ vault_r2_access_key_id }}
R2_SECRET_ACCESS_KEY={{ vault_r2_secret_access_key }}
R2_BUCKET_NAME=samscollectibles
R2_ENDPOINT_URL={{ vault_r2_endpoint_url }}
R2_CUSTOM_DOMAIN=media.{{ domain }}

# Email
EMAIL_HOST_USER={{ vault_email_host_user }}
EMAIL_HOST_PASSWORD={{ vault_email_host_password }}
DEFAULT_FROM_EMAIL={{ vault_email_host_user }}

# eBay API
EBAY_APP_ID={{ vault_ebay_app_id }}
EBAY_CERT_ID={{ vault_ebay_cert_id }}
EBAY_DEV_ID={{ vault_ebay_dev_id }}
EBAY_RUNAME={{ vault_ebay_runame }}

# Timezone
TIME_ZONE=America/Los_Angeles
